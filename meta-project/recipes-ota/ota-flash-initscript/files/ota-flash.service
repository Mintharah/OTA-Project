[Unit]
Description=OTA Flash Service
After=network.target

[Service]
Environment="VSOMEIP_APPLICATION_NAME=OTAFlashService"
Environment="VSOMEIP_CONFIGURATION=/etc/vsomeip-ota.json"
Environment="COMMONAPI_CONFIG=/etc/commonapi.ini"
Environment="COMMONAPI_DEFAULT_BINDING=someip"
ExecStart=/usr/bin/ota-flash-service
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target